{
  "format_version": "1.21.40",
  "minecraft:entity": {
    "description": {
      "identifier": "cb:adv_guild_guard_two",
      "spawn_category": "monster",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,

      "properties": {
        "cb:is_attacking": {
          "type": "bool",
          "default": false,
          "client_sync": true
        }
      }
    },

    "component_groups": {
      "cb:attack_timer": {
        "minecraft:timer": {
          "looping": false,
          "time": 1.5,
          "time_down_event": {
            "event": "cb:stop_attack"
          }
        }
      }
    },

    "components": {
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 90 + (query.equipment_count * Math.Random(20,40)) : 0"
      },

      "minecraft:health": {
        "value": 50,
        "max": 50
      },

      "minecraft:collision_box": {
        "height": 2.01,
        "width": 0.72
      },

      "minecraft:attack": {
        "damage": 4,
        "effect_name": "slowness",
        "effect_duration": 30
      },

      "minecraft:movement": {
        "value": 0.30
      },

      "minecraft:navigation.walk": {
        "is_amphibious": true,
        "avoid_sun": false,
        "avoid_water": false,
        "can_path_over_lava": false
      },

      "minecraft:target_nearby_sensor": {
        "inside_range": 16,
        "outside_range": 20,
        "must_see": true,
        "on_inside_range": {
          "event": "minecraft:start_exploding_forced"
        }
      },

      "minecraft:shareables": {
        "singular_pickup": true,
        "items": [
          {
            "item": "minecraft:netherite_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 0
          },
          {
            "item": "minecraft:diamond_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 1
          },
          {
            "item": "minecraft:iron_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 2
          },
          {
            "item": "minecraft:stone_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 3
          },
          {
            "item": "minecraft:golden_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 4
          },
          {
            "item": "minecraft:wooden_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 5
          }
        ]
      },

      "minecraft:scale": {
        "value": 1.2
      },

      "minecraft:behavior.float": {
        "priority": 0
      },

      "minecraft:behavior.nearest_attackable_target": {
        "priority": 1,
        "reselect_targets": true,
        "must_see": true,
        "entity_types": [
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "monster"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "operator": "!=",
                  "value": "player"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "operator": "!=",
                  "value": "cb_guard"
                }
              ]
            },
            "max_dist": 20
          }
        ]
      },

      "minecraft:behavior.hurt_by_target": {
        "priority": 2
      },

      "minecraft:behavior.melee_attack": {
        "priority": 3,
        "speed_multiplier": 1.2,
        "track_target": true,
        "reach_multiplier": 2.0,
        "random_stop_interval": 0,
        "on_attack": {
          "event": "cb:start_attack"
        }
      },

      "minecraft:behavior.equip_item": {
        "priority": 4
      },

      "minecraft:behavior.pickup_items": {
        "can_pickup_any_item": false,
        "can_pickup_to_hand_or_equipment": true,
        "cooldown_after_being_attacked": 20,
        "goal_radius": 2,
        "max_dist": 3,
        "pickup_based_on_chance": true,
        "speed_multiplier": 1
      },

      "minecraft:behavior.random_stroll": {
        "priority": 5,
        "speed_multiplier": 1
      },

      "minecraft:behavior.look_at_player": {
        "priority": 6,
        "look_distance": 8
      },

      "minecraft:behavior.random_look_around": {
        "priority": 7
      },

      "minecraft:type_family": {
        "family": [
          "cb_guard"
        ]
      },

      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },

      "minecraft:underwater_movement": {
        "value": 0.02
      },

      "minecraft:physics": {
        "has_gravity": true
      },

      "minecraft:knockback_resistance": {
        "value": 0.0,
        "max": 0.0
      },

      "minecraft:movement.basic": {
        "max_turn": 30
      },

      "minecraft:loot": {
        "table": "loot_tables/entities/cb_dark_elf_knight.json"
      },

      "minecraft:equipment": {
        "table": "loot_tables/entities/cb_dark_elf_knight_equipment.json"
      }
    },

    "events": {
      "cb:start_attack": {
        "set_property": {
          "cb:is_attacking": true
        },
        "add": {
          "component_groups": [
            "cb:attack_timer"
          ]
        }
      },

      "cb:stop_attack": {
        "set_property": {
          "cb:is_attacking": false
        },
        "remove": {
          "component_groups": [
            "cb:attack_timer"
          ]
        }
      }
    }
  }
}