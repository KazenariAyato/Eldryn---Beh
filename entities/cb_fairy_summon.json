{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cb:fairy_summon",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "pickup_item_delay": {
        "minecraft:timer": {
          "looping": false,
          "time": 3,
          "time_down_event": {
            "event": "pickup_item_delay_complete"
          }
        }
      },
      "pickup_item": {
        "minecraft:behavior.pickup_items": {
          "priority": 2,
          "max_dist": 32,
          "search_height": 32,
          "goal_radius": 2.2,
          "speed_multiplier": 6,
          "pickup_based_on_chance": false,
          "can_pickup_any_item": false,
          "can_pickup_to_hand_or_equipment": false,
          "pickup_same_items_as_in_hand": true
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": [
          "allay",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "height": 0.6,
        "width": 0.35
      },
      "minecraft:balloonable": {
        "mass": 0.5
      },
      "minecraft:breathable": {
        "totalSupply": 15,
        "suffocateTime": 0
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.1
      },
      "minecraft:navigation.hover": {
        "can_path_over_water": true,
        "can_sink": false,
        "can_pass_doors": false,
        "can_path_from_air": true,
        "avoid_water": true,
        "avoid_damage_blocks": true,
        "avoid_sun": false
      },
      "minecraft:follow_range": {
        "value": 1024
      },
      "minecraft:ambient_sound_interval": {
        "value": 5.0,
        "range": 5.0,
        "event_name": "ambient",
        "event_names": [
          {
            "event_name": "ambient.tame",
            "condition": "query.is_using_item"
          },
          {
            "event_name": "ambient",
            "condition": "!query.is_using_item"
          }
        ]
      },
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:game_event_movement_tracking": {
        "emit_flap": true
      },
      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": {
              "filters": {
                "all_of": [
                  {
                    "test": "is_family",
                    "subject": "other",
                    "value": "player"
                  },
                  {
                    "test": "is_sneak_held",
                    "subject": "other",
                    "value": false
                  }
                ]
              }
            },
            "give_item": true,
            "take_item": true,
            "interact_text": "action.interact.allay"
          }
        ]
      },
      "minecraft:behavior.go_and_give_items_to_noteblock": {
        "priority": 3,
        "run_speed": 8,
        "throw_sound": "item_thrown",
        "on_item_throw": [
          {
            "event": "pickup_item_delay",
            "target": "self"
          }
        ]
      },
      "minecraft:behavior.go_and_give_items_to_owner": {
        "priority": 4,
        "run_speed": 8,
        "throw_sound": "item_thrown",
        "on_item_throw": [
          {
            "event": "pickup_item_delay",
            "target": "self"
          }
        ]
      },
      "minecraft:behavior.stay_near_noteblock": {
        "priority": 5,
        "speed": 8,
        "start_distance": 16,
        "stop_distance": 4
      },
      "minecraft:behavior.follow_owner": {
        "start_distance": 10,
        "speed_multiplier": 1,
        "stop_distance": 2,
        "priority": 6
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "target_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:behavior.random_hover": {
        "priority": 9,
        "xz_dist": 8,
        "y_dist": 8,
        "y_offset": -1,
        "interval": 1,
        "hover_height": [
          1,
          4
        ]
      },
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 10 : 0"
      },
      "minecraft:underwater_movement": {
        "value": 0.02
      },
      "minecraft:scale": {
        "value": 1
      },
      "minecraft:attack": {
        "damage": 0.1,
        "effect_name": "regeneration",
        "effect_duration": 30
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 3,
        "within_radius": 25,
        "must_reach": true,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                }
              ]
            },
            "max_dist": 0.1,
            "must_see": true
          }
        ],
        "must_see": true
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 3
      },
      "minecraft:behavior.owner_hurt_by_target": {
        "priority": 1
      },
      "minecraft:behavior.owner_hurt_target": {
        "priority": 2
      },
      "minecraft:behavior.float_wander": {
        "must_reach": true,
        "random_reselect": true,
        "priority": 2,
        "float_duration": [
          0.1,
          0.35
        ]
      },
      "minecraft:behavior.melee_attack": {
        "priority": 2,
        "speed_multiplier": 1,
        "random_stop_interval": 100,
        "track_target": false,
        "reach_multiplier": 1.4
      },
      "minecraft:navigation.fly": {
        "avoid_damage_blocks": true,
        "avoid_portals": true,
        "avoid_sun": false,
        "avoid_water": false,
        "can_breach": false,
        "can_break_doors": true,
        "can_jump": true,
        "can_open_doors": false,
        "can_open_iron_doors": false,
        "can_pass_doors": false,
        "can_path_from_air": true,
        "can_path_over_lava": true,
        "can_path_over_water": true,
        "can_sink": true,
        "can_swim": false,
        "can_walk": true,
        "can_walk_in_lava": false,
        "is_amphibious": false
      },
      "minecraft:behavior.ranged_attack": {
        "attack_interval_min": 1,
        "attack_interval_max": 3,
        "attack_radius": 15,
        "burst_shots": 1,
        "burst_interval": 0.5
      },
      "minecraft:shooter": {
        "def": "minecraft:arrow.skeleton"
      },
      "minecraft:area_attack": {
        "damage_range": 0.0,
        "damage_per_tick": 0,
        "cause": "contact",
        "entity_filter": {
          "all_of": [
            {
              "test": "is_family",
              "subject": "other",
              "value": "player",
              "operator": "!="
            }
          ]
        }
      },
      "minecraft:lookat": {
        "allow_invulnerable": false,
        "filters": {
          "test": "has_target"
        },
        "search_radius": 10.0,
        "set_target": true
      },
      "minecraft:physics": {
        "has_gravity": true
      },
      "minecraft:knockback_resistance": {
        "value": 0.0,
        "max": 0.0
      },
      "minecraft:flying_speed": {
        "value": 0.02
      },
      "minecraft:movement.basic": {
        "max_turn": 30.0
      }
    },
    "events": {
      "pickup_item_delay": {
        "remove": {
          "component_groups": [
            "pickup_item"
          ]
        },
        "add": {
          "component_groups": [
            "pickup_item_delay"
          ]
        }
      },
      "pickup_item_delay_complete": {
        "remove": {
          "component_groups": [
            "pickup_item_delay"
          ]
        },
        "add": {
          "component_groups": [
            "pickup_item"
          ]
        }
      },
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "pickup_item"
          ]
        }
      }
    }
  }
}