{
  "format_version": "1.20.10",
  "minecraft:entity": {
    "description": {
      "identifier": "cb:butterfly",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },

    "components": {
      "minecraft:type_family": {
        "family": [
          "butterfly",
          "mob"
        ]
      },

      "minecraft:variant": {
  "value": 0
},

      "minecraft:health": {
        "value": 2,
        "max": 2
      },

      "minecraft:collision_box": {
        "width": 0.35,
        "height": 0.4
      },

      "minecraft:nameable": {},

      "minecraft:physics": {
        "has_gravity": false
      },

      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },

      "minecraft:movement.fly": {},

      "minecraft:navigation.fly": {
        "can_path_over_water": true,
        "avoid_water": false,
        "can_open_doors": false,
        "can_pass_doors": true
      },

      "minecraft:movement": {
        "value": 0.12
      },

      "minecraft:jump.static": {},

      "minecraft:behavior.float": {
        "priority": 1
      },

      "minecraft:behavior.random_fly": {
        "priority": 2,
        "speed_multiplier": 1.0,
        "xz_dist": 6,
        "y_dist": 2
      },

      "minecraft:behavior.random_stroll": {
        "priority": 3,
        "speed_multiplier": 0.3
      },

      "minecraft:behavior.look_at_player": {
        "priority": 4,
        "look_distance": 4,
        "probability": 0.02
      },

      "minecraft:behavior.idle": {
        "priority": 5
      },

      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 1 : 0"
      },

      "minecraft:damage_sensor": {
        "triggers": {
          "cause": "all",
          "deals_damage": true
        }
      },

      "minecraft:despawn": {
        "despawn_from_distance": {}
      },

      "minecraft:underwater_movement": {
        "value": 0.02
      },

      "minecraft:can_climb": false,

      "minecraft:preferred_path": {
        "default_block_cost": 0,
        "jump_cost": 1,
        "max_fall_blocks": 1
      },

      "minecraft:environment_sensor": {
        "triggers": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_block",
                  "subject": "block",
                  "operator": "==",
                  "value": "minecraft:grass_block"
                },
                {
                  "test": "is_block",
                  "subject": "block",
                  "operator": "==",
                  "value": "minecraft:oak_leaves"
                },
                {
                  "test": "is_block",
                  "subject": "block",
                  "operator": "==",
                  "value": "minecraft:birch_leaves"
                },
                {
                  "test": "is_block",
                  "subject": "block",
                  "operator": "==",
                  "value": "minecraft:jungle_leaves"
                }
              ]
            },
            "event": "cb:rest"
          }
        ]
      },

      "minecraft:timer": {
        "looping": true,
        "time": [4, 8],
        "time_down_event": {
          "event": "cb:resume_flying"
        }
      }
    },

    "component_groups": {
      "cb:resting": {
        "minecraft:movement": {
