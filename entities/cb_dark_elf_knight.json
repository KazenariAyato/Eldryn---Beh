{
  "format_version": "1.21.40",
  "minecraft:entity": {
    "description": {
      "identifier": "cb:dark_elf_knight",
      "spawn_category": "monster",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,

      "properties": {
        "cb:is_attacking": {
          "type": "bool",
          "default": false,
          "client_sync": true
        }
      }
    },

    "component_groups": {
      "cb:attack_timer": {
        "minecraft:timer": {
          "looping": false,
          "time": 1.5,
          "time_down_event": {
            "event": "cb:stop_attack"
          }
        }
      }
    },

    "components": {
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 90 + (query.equipment_count * Math.Random(1,3)) : 0"
      },

      "minecraft:health": {
        "value": 20,
        "max": 20
      },

      "minecraft:collision_box": {
        "height": 2.01,
        "width": 0.72
      },

      "minecraft:attack": {
        "damage": 4,
        "effect_name": "slowness",
        "effect_duration": 30
      },

      "minecraft:movement": {
        "value": 0.25
      },

      "minecraft:navigation.walk": {
        "is_amphibious": true,
        "avoid_sun": true,
        "avoid_water": true,
        "can_path_over_lava": true
      },

      "minecraft:shareables": {
        "singular_pickup": true,
        "items": [
          {
            "item": "minecraft:netherite_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 0
          },
          {
            "item": "minecraft:diamond_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 1
          },
          {
            "item": "minecraft:iron_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 2
          },
          {
            "item": "minecraft:stone_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 3
          },
          {
            "item": "minecraft:golden_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 4
          },
          {
            "item": "minecraft:wooden_sword",
            "want_amount": 1,
            "surplus_amount": 1,
            "priority": 5
          }
        ]
      },

      "minecraft:scale": {
        "value": 1.2
      },

      "minecraft:behavior.float": {
        "priority": 0,
        "speed_multiplier": 1
      },

      "minecraft:behavior.owner_hurt_by_target": {
        "priority": 1
      },

      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "reselect_targets": true,
        "must_see": true,
        "must_reach": true,
        "within_radius": 0.0,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "creeper"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "skeleton"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "spider"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "stray"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "zombie"
                }
              ]
            },
            "max_dist": 16.0,
            "must_see": true
          },
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "piglin"
                },
                {
                  "test": "is_difficulty",
                  "operator": "!=",
                  "value": "peaceful"
                }
              ]
            },
            "max_dist": 16
          },
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "irongolem"
            },
            "max_dist": 16
          },
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "baby_turtle"
                },
                {
                  "test": "in_water",
                  "subject": "other",
                  "operator": "!=",
                  "value": true
                }
              ]
            },
            "max_dist": 16
          }
        ]
      },

      "minecraft:behavior.melee_attack": {
        "priority": 3,
        "speed_multiplier": 1,
        "random_stop_interval": 100,
        "track_target": true,
        "reach_multiplier": 1.4,
        "on_attack": {
          "event": "cb:start_attack"
        }
      },

      "minecraft:behavior.hurt_by_target": {
        "priority": 4
      },

      "minecraft:behavior.owner_hurt_target": {
        "priority": 5
      },

      "minecraft:behavior.equip_item": {
        "priority": 6
      },

      "minecraft:behavior.pickup_items": {
        "can_pickup_any_item": false,
        "can_pickup_to_hand_or_equipment": false,
        "cooldown_after_being_attacked": 20.0,
        "goal_radius": 2.0,
        "max_dist": 3.0,
        "pickup_based_on_chance": true,
        "speed_multiplier": 1.0,
        "track_target": false
      },

      "minecraft:behavior.random_stroll": {
        "priority": 7,
        "speed_multiplier": 1
      },

      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 8
      },

      "minecraft:behavior.random_look_around": {
        "priority": 9
      },

      "minecraft:type_family": {
        "family": [
          "undead"
        ]
      },

      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },

      "minecraft:underwater_movement": {
        "value": 0.02
      },

      "minecraft:physics": {
        "has_gravity": true
      },

      "minecraft:knockback_resistance": {
        "value": 0.0,
        "max": 0.0
      },

      "minecraft:movement.basic": {
        "max_turn": 30.0
      },

      "minecraft:loot": {
        "table": "loot_tables/entities/cb_dark_elf_knight.json"
      },

      "minecraft:equipment": {
        "table": "loot_tables/entities/cb_dark_elf_knight_equipment.json"
      }
    },

    "events": {
      "cb:start_attack": {
        "set_property": {
          "cb:is_attacking": true
        },
        "add": {
          "component_groups": [
            "cb:attack_timer"
          ]
        }
      },

      "cb:stop_attack": {
        "set_property": {
          "cb:is_attacking": false
        },
        "remove": {
          "component_groups": [
            "cb:attack_timer"
          ]
        }
      }
    }
  }
}